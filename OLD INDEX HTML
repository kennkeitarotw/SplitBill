      // ─── Render: Settlement ───────────────────────────────────────────────────
      function renderSettlement(settlements, balances) {
        els.settlementList.innerHTML = settlements.map(tx => {
          const fromName = escapeHtml(personName(tx.from));
          const toName = escapeHtml(personName(tx.to));
          const fromBal = money(balances[tx.from]);
          const toBal = money(balances[tx.to]);
          const whyText = `${escapeHtml(personName(tx.from))}'s balance is ${fmt(Math.abs(fromBal))} in the red. ${escapeHtml(personName(tx.to))}'s balance is ${fmt(toBal)} in credit. Paying ${fmt(tx.amount)} balances both out.`;

          return `
            <div class="settlement-card" id="stl-${tx.from}-${tx.to}">
              <div class="settlement-main-row">
                <div class="settlement-main">
                  <span class="badge red">Pay</span>
                  <div>
                    <div class="name">${fromName} → ${toName}</div>
                    <div class="sub">One clean transaction</div>
                  </div>
                </div>
                <div class="settlement-actions">
                  <button class="ghost sm" data-why-toggle="${tx.from}-${tx.to}">Why?</button>
                  <button class="success-btn sm" data-mark-paid="${tx.from}-${tx.to}">Mark paid</button>
                  <div class="money">${fmt(tx.amount)}</div>
                </div>
              </div>
              <div class="settlement-why" id="why-${tx.from}-${tx.to}">${whyText}</div>
            </div>
          `;
        }).join('');
        els.settlementEmpty.style.display = settlements.length ? 'none' : 'block';
      }

      // ─── Render: Balances ─────────────────────────────────────────────────────
      function renderBalances(calc) {
        if (!state.people.length) { els.balanceEmpty.style.display = 'block'; return; }
        els.balanceEmpty.style.display = 'none';
        els.balanceList.innerHTML = state.people.map(person => {
          const balance = money(calc.balances[person.id]);
          const badge = balance > 0.009
            ? `<span class="badge green">Gets back</span>`
            : balance < -0.009
              ? `<span class="badge red">Needs to pay</span>`
              : `<span class="badge blue">Settled</span>`;

          let summaryLine = '';
          if (state.expenses.length > 0) {
            if (balance > 0.009)
              summaryLine = `<div class="person-summary-line gets">should receive ${fmt(balance)}</div>`;
            else if (balance < -0.009)
              summaryLine = `<div class="person-summary-line owes">should pay ${fmt(Math.abs(balance))}</div>`;
            else
              summaryLine = `<div class="person-summary-line settled">is fully settled</div>`;
          }

          return `
            <div class="balance-item">
              <div class="balance-left">
                <div class="name">${escapeHtml(person.name)}</div>
                <div class="sub">Paid ${fmt(calc.paid[person.id] || 0)} · Owed ${fmt(calc.owed[person.id] || 0)}</div>
                ${summaryLine}
              </div>
              <div style="text-align:right">
                ${badge}
                <div class="money" style="font-size:18px;margin-top:6px">${balance >= 0 ? '+' : '-'}${fmt(Math.abs(balance))}</div>
              </div>
            </div>
          `;
        }).join('');
      }

      // ─── Render: Stats ────────────────────────────────────────────────────────
      function renderStats(calc) {
        els.statTotal.textContent = fmtNum(calc.total);
        els.statPeople.textContent = String(state.people.length);
        els.statExpenses.textContent = String(state.expenses.length);
      }

      // ─── Render: All ──────────────────────────────────────────────────────────
      function render() {
        renderPeople();
        renderParticipantsAndPayer();
        renderSharesEditor();
        const calc = compute();
        renderExpenses(calc.expenseBreakdown);
        renderSettlement(calc.settlements, calc.balances);
        renderBalances(calc);
        renderStats(calc);
      }

      // ─── Export / Import ──────────────────────────────────────────────────────
      function exportJson() {
        const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a'); a.href = url; a.download = 'split-bill-data.json'; a.click();
        URL.revokeObjectURL(url);
        showToast('Exported as JSON ✓');
      }

      function importJson(file) {
        const reader = new FileReader();
        reader.onload = () => {
          try {
            const parsed = JSON.parse(reader.result);
            if (!parsed || !Array.isArray(parsed.people) || !Array.isArray(parsed.expenses)) throw new Error('Invalid format');
            state = parsed;
            save(); render();
            showToast('Import successful ✓');
          } catch (e) {
            showToast('Could not import this file.', 'info');
          }
        };
        reader.readAsText(file);
      }

      // ─── Copy settlement ──────────────────────────────────────────────────────
      function copySettlement() {
        const calc = compute();
        if (!calc.settlements.length) { showToast('Nothing to copy — no settlements.', 'info'); return; }
        const lines = [
          `Split Bill Settlement — ${new Date().toLocaleDateString()}`,
          `Currency: ${currency.code} (${currency.symbol})`,
          `Total: ${fmt(calc.total)}`,
          '',
          '=== Transactions ===',
          ...calc.settlements.map(tx =>
            `${personName(tx.from)} → ${personName(tx.to)}: ${fmt(tx.amount)}`
          ),
          '',
          '=== Balances ===',
          ...state.people.map(p => {
            const bal = money(calc.balances[p.id]);
            if (bal > 0.009) return `${p.name}: receives ${fmt(bal)}`;
            if (bal < -0.009) return `${p.name}: pays ${fmt(Math.abs(bal))}`;
            return `${p.name}: settled`;
          })
        ];
        navigator.clipboard.writeText(lines.join('\n')).then(() => {
          showToast('Settlement copied to clipboard ✓');
        }).catch(() => {
          showToast('Could not copy — check browser permissions.', 'info');
        });
      }

      // ─── Event delegation ─────────────────────────────────────────────────────
      document.addEventListener('click', e => {
        const removePersonId = e.target.getAttribute('data-remove-person');
        const removeExpenseId = e.target.getAttribute('data-remove-expense');
        const editToggleId = e.target.getAttribute('data-edit-toggle');
        const saveEditId = e.target.getAttribute('data-save-edit');
        const cancelEditId = e.target.getAttribute('data-cancel-edit');
        const markPaidKey = e.target.getAttribute('data-mark-paid');
        const whyToggleKey = e.target.getAttribute('data-why-toggle');
        const templateKey = e.target.getAttribute('data-template');

        if (removePersonId) { removePerson(removePersonId); return; }
        if (removeExpenseId) { removeExpense(removeExpenseId); return; }

        if (editToggleId) {
          const form = document.getElementById(`edit-form-${editToggleId}`);
          if (form) form.classList.toggle('open');
          return;
        }
        if (saveEditId) { saveInlineEdit(saveEditId); return; }
        if (cancelEditId) {
          const form = document.getElementById(`edit-form-${cancelEditId}`);
          if (form) form.classList.remove('open');
          return;
        }
        if (markPaidKey) {
          const card = document.getElementById(`stl-${markPaidKey}`);
          if (!card) return;
          const isPaid = card.classList.toggle('paid-off');
          const btn = e.target;
          btn.textContent = isPaid ? '↩ Undo' : 'Mark paid';
          return;
        }
        if (whyToggleKey) {
          const why = document.getElementById(`why-${whyToggleKey}`);
          if (why) why.classList.toggle('open');
          return;
        }
        if (templateKey) {
          const tpl = TEMPLATES[templateKey];
          if (tpl) {
            els.expenseTitle.value = tpl.title;
            els.expenseCategory.value = tpl.category;
            els.expenseAmount.focus();
          }
          return;
        }
      });

      // ─── Wiring ───────────────────────────────────────────────────────────────
      els.addPersonBtn.addEventListener('click', addPerson);
      els.personName.addEventListener('keydown', e => { if (e.key === 'Enter') addPerson(); });
      els.addExpenseBtn.addEventListener('click', addExpense);
      els.clearExpenseFormBtn.addEventListener('click', clearExpenseForm);
      els.splitMode.addEventListener('change', renderSharesEditor);
      els.participantsBox.addEventListener('change', renderSharesEditor);
      els.sampleBtn.addEventListener('click', () => { loadSample(true); showToast('Sample data loaded ✓'); });
      els.exportBtn.addEventListener('click', exportJson);
      els.importBtn.addEventListener('click', () => els.importFile.click());
      els.importFile.addEventListener('change', e => {
        const file = e.target.files?.[0];
        if (file) importJson(file);
        e.target.value = '';
      });
      els.resetBtn.addEventListener('click', () => {
        if (!confirm('Reset all people and expenses?')) return;
        state = { people: [], expenses: [] };
        save(); render();
        showToast('Reset complete.');
      });
      els.currencySelect.addEventListener('change', () => {
        const code = els.currencySelect.value;
        currency = { code, symbol: CURRENCIES[code] };
        render();
      });
      els.copySettlementBtn.addEventListener('click', copySettlement);
      els.searchInput.addEventListener('input', () => { const calc = compute(); renderExpenses(calc.expenseBreakdown); });
      els.filterCategory.addEventListener('change', () => { const calc = compute(); renderExpenses(calc.expenseBreakdown); });
      els.filterPayer.addEventListener('change', () => { const calc = compute(); renderExpenses(calc.expenseBreakdown); });

      // ─── Boot ─────────────────────────────────────────────────────────────────
      load();
      render();
      window.splitBillPro = { getState: () => state, compute };
    })();
  </script>
</body>
</html>
