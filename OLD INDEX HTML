          if (raw) {
            const parsed = JSON.parse(raw);
            if (parsed && Array.isArray(parsed.people) && Array.isArray(parsed.expenses)) {
              state = parsed;
              return;
            }
          }
        } catch (_) {}
        loadSample(false);
      }

