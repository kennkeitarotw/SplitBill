          const balance = money(calc.balances[person.id]);
          let chip = '';
          if (balance > 0.009) chip = `<span class="balance-chip positive">+${fmt(balance)}</span>`;
          else if (balance < -0.009) chip = `<span class="balance-chip negative">−${fmt(Math.abs(balance))}</span>`;
          else if (state.expenses.length > 0) chip = `<span class="balance-chip neutral">settled</span>`;
          return `
            <div class="person-pill">
              <div>
                ${escapeHtml(person.name)}
                ${chip}
              </div>
              <button class="x" data-remove-person="${person.id}" title="Remove">×</button>
