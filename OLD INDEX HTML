<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Split Bill Pro</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;0,9..40,800;1,9..40,400&family=DM+Mono:wght@400;500&display=swap');
    :root{
      --bg: #f6f8fc;
      --bg-2: #eef3ff;
      --card: rgba(255,255,255,.88);
      --card-solid:#fff;
      --text:#0f172a;
      --muted:#64748b;
      --line:#e5e7eb;
      --primary:#2563eb;
      --primary-2:#1d4ed8;
      --success:#16a34a;
      --danger:#dc2626;
      --warning:#d97706;
      --shadow: 0 16px 40px rgba(15,23,42,.08);
      --radius: 20px;
    }
    *{box-sizing:border-box}
    html,body{margin:0;padding:0;font-family:'DM Sans',Inter,ui-sans-serif,system-ui,-apple-system,sans-serif;color:var(--text);background:
      radial-gradient(circle at top left, #dbeafe 0%, transparent 35%),
      radial-gradient(circle at top right, #e9d5ff 0%, transparent 28%),
      linear-gradient(180deg, #f8fbff 0%, #f5f7fb 100%);
      min-height:100%;}
    .container{max-width:1200px;margin:0 auto;padding:24px 16px 48px}
    .hero{display:flex;gap:16px;align-items:flex-start;justify-content:space-between;margin-bottom:12px;flex-wrap:wrap}
    .hero h1{font-size:clamp(24px,3.5vw,38px);margin:0 0 4px;line-height:1.1;font-weight:800}
    .hero-subtitle{font-size:14px;font-weight:700;color:var(--primary);margin:0 0 6px;letter-spacing:.01em}
    .hero p{margin:0;color:var(--muted);max-width:640px;font-size:14px;line-height:1.6}
    .top-actions{display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    .layout{display:grid;grid-template-columns: 1.1fr .9fr;gap:18px}
    .left,.right{display:flex;flex-direction:column;gap:18px}
    .card{
      background:var(--card);
      backdrop-filter: blur(16px);
      border:1px solid rgba(255,255,255,.9);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
      overflow:hidden;
    }
    .card-header{padding:18px 20px 0}
    .card-body{padding:18px 20px 20px}
    .card h2,.card h3{margin:0}
    .section-title{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:4px}
    .eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:12px;font-weight:700;color:var(--primary);text-transform:uppercase;letter-spacing:.08em}
    .muted{color:var(--muted)}
    .grid-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    .grid-4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
    .stack{display:flex;flex-direction:column;gap:12px}
    .input-group{display:flex;flex-direction:column;gap:6px}
    label{font-size:13px;font-weight:600;color:#334155}
    input,select,textarea{
      width:100%;padding:12px 14px;border-radius:14px;border:1px solid var(--line);
      background:#fff;font-size:14px;color:var(--text);outline:none;transition:.18s ease;
      font-family:inherit;
    }
    input:focus,select:focus,textarea:focus{border-color:#93c5fd;box-shadow:0 0 0 4px rgba(37,99,235,.12)}
    textarea{resize:vertical;min-height:70px}
    button{
      border:none;background:var(--primary);color:#fff;padding:12px 16px;border-radius:14px;
      font-weight:700;cursor:pointer;transition:.18s ease;box-shadow:0 10px 18px rgba(37,99,235,.18);
      font-family:inherit;font-size:14px;
    }
    button:hover{transform:translateY(-1px);background:var(--primary-2)}
    button.secondary{background:#fff;color:var(--text);border:1px solid var(--line);box-shadow:none}
    button.secondary:hover{background:#f8fafc}
    button.ghost{background:transparent;color:var(--primary);border:1px solid rgba(37,99,235,.18);box-shadow:none}
    button.danger{background:#fff1f2;color:var(--danger);border:1px solid #fecdd3;box-shadow:none}
    button.success-btn{background:#ecfdf5;color:var(--success);border:1px solid #bbf7d0;box-shadow:none}
    button.sm{padding:7px 12px;font-size:12px;border-radius:10px}
    .pill-row{display:flex;flex-wrap:wrap;gap:10px}
    .person-pill{display:inline-flex;align-items:center;gap:10px;padding:10px 14px;border-radius:999px;background:#fff;border:1px solid var(--line);font-weight:700;transition:.15s ease}
    .person-pill:hover{border-color:#bfdbfe}
    .person-pill small{display:block;color:var(--muted);font-weight:600;font-size:11px}
    .person-pill .x{background:none;border:none;color:var(--muted);padding:0;box-shadow:none;font-size:16px;line-height:1;transform:none}
    .person-pill .x:hover{color:var(--danger);transform:none}
    /* Balance chips */
    .balance-chip{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:999px;font-size:11px;font-weight:700;white-space:nowrap}
    .balance-chip.positive{background:#ecfdf5;color:var(--success);border:1px solid #bbf7d0}
    .balance-chip.negative{background:#fef2f2;color:var(--danger);border:1px solid #fecdd3}
    .balance-chip.neutral{background:#eff6ff;color:var(--primary);border:1px solid #bfdbfe}
    .stats{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
    .stat{background:linear-gradient(180deg,#fff,#f8fbff);border:1px solid #e7eef9;border-radius:18px;padding:14px}
    .stat .k{font-size:12px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}
    .stat .v{font-size:26px;font-weight:800;margin-top:8px;font-family:'DM Mono',monospace}
    .badge{display:inline-flex;align-items:center;gap:6px;border-radius:999px;padding:6px 10px;font-size:12px;font-weight:800}
    .badge.green{background:#ecfdf5;color:var(--success)}
    .badge.red{background:#fef2f2;color:var(--danger)}
    .badge.blue{background:#eff6ff;color:var(--primary)}
    .expense-list,.settlement-list,.balance-list{display:flex;flex-direction:column;gap:12px}
    .expense-card{background:var(--card-solid);border:1px solid var(--line);border-radius:18px;padding:14px;transition:.18s ease}
    .expense-card:hover{border-color:#bfdbfe;box-shadow:0 4px 16px rgba(37,99,235,.07)}
    .expense-top{display:flex;justify-content:space-between;gap:12px;align-items:flex-start;flex-wrap:wrap}
    .expense-title{font-size:16px;font-weight:800;margin:0 0 4px}
    .expense-meta{font-size:13px;color:var(--muted);display:flex;gap:10px;flex-wrap:wrap;align-items:center}
    .expense-bottom{display:flex;justify-content:space-between;gap:10px;align-items:center;margin-top:12px;flex-wrap:wrap}
    .expense-actions{display:flex;gap:8px;flex-shrink:0}
    .chips{display:flex;flex-wrap:wrap;gap:8px}
    .chip{padding:5px 10px;border-radius:999px;background:#f8fafc;border:1px solid #e2e8f0;font-size:12px;font-weight:700}
    .chip.cat{background:#eff6ff;border-color:#bfdbfe;color:var(--primary)}
    /* Inline edit form */
    .inline-edit-form{background:#f8fafc;border:1px solid #bfdbfe;border-radius:14px;padding:14px;margin-top:10px;display:none}
    .inline-edit-form.open{display:block}
    .settlement-card{border-radius:18px;background:#fff;border:1px solid var(--line);overflow:hidden;transition:.18s ease}
    .settlement-card:hover{border-color:#bfdbfe}
    .settlement-main-row{display:flex;justify-content:space-between;align-items:center;gap:14px;padding:14px 16px;flex-wrap:wrap}
    .settlement-main{display:flex;align-items:center;gap:12px;flex-wrap:wrap}
    .settlement-actions{display:flex;align-items:center;gap:8px;flex-shrink:0}
    .settlement-why{font-size:12px;color:var(--muted);padding:10px 16px;border-top:1px solid var(--line);background:#fafbfd;display:none}
    .settlement-why.open{display:block}
    .settlement-card.paid-off{opacity:.65}
    .settlement-card.paid-off .settlement-main-row{text-decoration:line-through;color:var(--muted)}
    .paid-badge{display:inline-flex;align-items:center;gap:5px;padding:4px 10px;border-radius:999px;font-size:11px;font-weight:700;background:#ecfdf5;color:var(--success);border:1px solid #bbf7d0}
    .money{font-weight:900;font-size:22px;font-family:'DM Mono',monospace}
    .big-result{padding:18px;border-radius:22px;background:linear-gradient(135deg,#eff6ff 0%,#ffffff 100%);border:1px solid #dbeafe}
    .big-result h3{font-size:22px;margin-bottom:6px;font-weight:800}
    .big-result p{margin:0;color:var(--muted);line-height:1.6;font-size:14px}
    .balance-item{display:flex;justify-content:space-between;align-items:center;gap:10px;background:#fff;border:1px solid var(--line);padding:14px 16px;border-radius:16px}
    .balance-left{display:flex;flex-direction:column;gap:4px}
    .name{font-weight:800}
    .sub{font-size:12px;color:var(--muted)}
    .person-summary{font-size:12px;color:var(--muted);font-style:italic;margin-top:2px}
    details{border-top:1px solid #e2e8f0}
    details:first-of-type{border-top:none}
    summary{list-style:none;cursor:pointer;padding:16px 0;font-weight:800;display:flex;justify-content:space-between;align-items:center;gap:10px}
    summary::-webkit-details-marker{display:none}
    .hint{font-size:13px;color:var(--muted);line-height:1.6}
    .checkbox-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
    .check{display:flex;align-items:center;gap:10px;padding:10px 12px;border:1px solid var(--line);border-radius:14px;background:#fff}
    .check input{width:auto;margin:0}
    .share-row{display:grid;grid-template-columns:1fr 120px;gap:10px;align-items:center}
    .toolbar{display:flex;gap:10px;flex-wrap:wrap}
    .footer-note{font-size:13px;color:var(--muted);text-align:center;margin-top:12px}
    .empty{padding:20px 16px;border:1px dashed #cbd5e1;border-radius:16px;background:#fff;color:var(--muted);text-align:center;line-height:1.6}
    .empty strong{display:block;color:#334155;margin-bottom:4px;font-size:14px}
    /* Currency selector */
    .currency-bar{display:flex;align-items:center;gap:10px;padding:10px 16px;background:#fff;border:1px solid var(--line);border-radius:14px;margin-bottom:18px;flex-wrap:wrap}
    .currency-bar label{font-size:13px;font-weight:700;color:#334155;white-space:nowrap}
    .currency-select{width:auto;padding:8px 12px;font-size:13px;border-radius:10px}
    /* Search + filter bar */
    .filter-bar{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}
    .filter-bar input,.filter-bar select{flex:1;min-width:120px;padding:9px 12px;font-size:13px;border-radius:10px}
    /* Quick templates */
    .templates-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:4px}
    .template-btn{padding:7px 14px;font-size:12px;border-radius:999px;background:#eff6ff;color:var(--primary);border:1px solid #bfdbfe;box-shadow:none;font-weight:700;transition:.15s ease}
    .template-btn:hover{background:#dbeafe;transform:translateY(-1px)}
    /* Toast */
    #toast-container{position:fixed;bottom:28px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;gap:10px;z-index:9999;pointer-events:none}
    .toast{background:#0f172a;color:#fff;padding:12px 20px;border-radius:14px;font-size:14px;font-weight:600;box-shadow:0 8px 28px rgba(15,23,42,.22);opacity:0;transform:translateY(16px);transition:.28s cubic-bezier(.4,0,.2,1);white-space:nowrap}
    .toast.show{opacity:1;transform:translateY(0)}
    .toast.toast-success{background:#166534;border:1px solid #22c55e22}
    .toast.toast-info{background:#1e3a8a}
    /* Category pill */
    .cat-icon{margin-right:3px}
    /* Settlement copy area */
    .settlement-header-row{display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:14px}
    /* Summary line per person */
    .person-summary-line{font-size:12px;margin-top:2px;font-style:italic}
    .person-summary-line.gets{color:var(--success)}
    .person-summary-line.owes{color:var(--danger)}
    .person-summary-line.settled{color:var(--muted)}
    @media (max-width: 980px){
      .layout{grid-template-columns:1fr}
      .right{order:-1}
    }
    @media (max-width: 680px){
      .stats,.grid-2,.grid-3,.grid-4,.checkbox-grid{grid-template-columns:1fr}
      .container{padding:16px 12px 32px}
      .card-body,.card-header{padding-left:16px;padding-right:16px}
      .settlement-card,.balance-item,.expense-bottom,.expense-top{align-items:flex-start}
    }
  </style>
</head>
<body>
  <div id="toast-container"></div>
  <div class="container">
    <section class="hero">
      <div>
        <div class="eyebrow">Split Bill Pro</div>
        <h1>Split billing for multiple payments, without the headache.</h1>
        <div class="hero-subtitle">Track who paid each expense, then settle fairly</div>
        <p>Perfect for trips, dinners, taxis, groceries, and shared purchases where different people pay at different times.</p>
      </div>
      <div class="top-actions">
        <button class="secondary" id="sampleBtn">Load sample</button>
        <button class="secondary" id="exportBtn">Export JSON</button>
        <button class="secondary" id="importBtn">Import JSON</button>
        <button class="secondary" id="resetBtn">Reset</button>
      </div>
    </section>

    <!-- Currency bar -->
    <div class="currency-bar">
      <label for="currencySelect">💱 Currency:</label>
      <select id="currencySelect" class="currency-select">
        <option value="TWD">TWD (NT$)</option>
        <option value="USD">USD ($)</option>
        <option value="IDR">IDR (Rp)</option>
        <option value="EUR">EUR (€)</option>
      </select>
      <span id="currencyNote" class="hint" style="margin:0">Display only — no conversion</span>
    </div>

    <div class="layout">
      <main class="left">
        <!-- People -->
        <section class="card">
          <div class="card-header">
            <div class="section-title">
              <div>
                <div class="eyebrow">Step 1</div>
                <h2>Group</h2>
              </div>
              <span class="badge blue" id="peopleCountBadge">0 people</span>
            </div>
          </div>
          <div class="card-body stack">
            <div class="grid-2">
              <div class="input-group">
                <label for="personName">Name</label>
                <input id="personName" placeholder="e.g. Alice" />
              </div>
              <div class="input-group" style="justify-content:flex-end">
                <label>&nbsp;</label>
                <button id="addPersonBtn">Add person</button>
              </div>
            </div>
            <div id="peopleList" class="pill-row"></div>
            <div id="peopleEmpty" class="empty"><strong>No one here yet</strong>Add at least 2 people to start splitting bills.</div>
          </div>
        </section>

        <!-- Add Expense -->
        <section class="card">
          <div class="card-header">
            <div class="section-title">
              <div>
                <div class="eyebrow">Step 2</div>
                <h2>Add an expense</h2>
              </div>
              <span class="badge blue">Quick by default</span>
            </div>
          </div>
          <div class="card-body stack">
            <!-- Quick templates -->
            <div>
              <div class="hint" style="margin-bottom:8px">Quick templates:</div>
              <div class="templates-row">
                <button class="template-btn" data-template="dinner">🍽️ Dinner</button>
                <button class="template-btn" data-template="taxi">🚕 Taxi</button>
                <button class="template-btn" data-template="groceries">🛒 Groceries</button>
                <button class="template-btn" data-template="trip">✈️ Trip</button>
              </div>
            </div>

            <div class="grid-3">
              <div class="input-group">
                <label for="expenseTitle">Expense name</label>
                <input id="expenseTitle" placeholder="e.g. Dinner, Taxi, Drinks" />
              </div>
              <div class="input-group">
                <label for="expenseAmount">Amount</label>
                <input id="expenseAmount" type="number" step="0.01" min="0" placeholder="0.00" />
              </div>
              <div class="input-group">
                <label for="expensePaidBy">Paid by</label>
                <select id="expensePaidBy"></select>
              </div>
            </div>

            <div class="grid-2">
              <div class="input-group">
                <label for="expenseCategory">Category</label>
                <select id="expenseCategory">
                  <option value="other">🗂️ Other</option>
                  <option value="food">🍽️ Food</option>
                  <option value="transport">🚕 Transport</option>
                  <option value="groceries">🛒 Groceries</option>
                  <option value="shopping">🛍️ Shopping</option>
                  <option value="accommodation">🏨 Accommodation</option>
                  <option value="entertainment">🎉 Entertainment</option>
                </select>
              </div>
              <div class="input-group">
                <label for="expenseDate">Date &amp; time <span class="muted">(optional)</span></label>
                <input id="expenseDate" type="datetime-local" />
              </div>
            </div>

            <div class="input-group">
              <label for="expenseNote">Note <span class="muted">(optional)</span></label>
              <input id="expenseNote" placeholder="e.g. at Blue Elephant restaurant" />
            </div>

            <div class="input-group">
              <label>Split among</label>
              <div id="participantsBox" class="checkbox-grid"></div>
            </div>

            <details>
              <summary>
                <span>Advanced split options</span>
                <span class="muted">Equal / Custom amount / Percentage</span>
              </summary>
              <div class="stack" style="padding-bottom:12px">
                <div class="grid-2">
                  <div class="input-group">
                    <label for="splitMode">Split mode</label>
                    <select id="splitMode">
                      <option value="equal">Equal split</option>
                      <option value="custom">Custom amount</option>
                      <option value="percent">Percentage</option>
                    </select>
                  </div>
                  <div class="input-group">
                    <label for="roundingRule">Rounding</label>
                    <select id="roundingRule">
                      <option value="nearest">Nearest</option>
                      <option value="up">Round up</option>
                      <option value="down">Round down</option>
                    </select>
                  </div>
                </div>
                <div id="sharesEditor" class="stack"></div>
                <div class="hint">Use custom or percentage only when the split is not equal. Otherwise, keep it simple.</div>
              </div>
            </details>

            <div class="toolbar">
              <button id="addExpenseBtn">Add expense</button>
              <button class="secondary" id="clearExpenseFormBtn">Clear form</button>
            </div>
          </div>
        </section>

        <!-- Expense list -->
        <section class="card">
          <div class="card-header">
            <div class="section-title">
              <div>
                <div class="eyebrow">Step 3</div>
                <h2>Expenses recorded</h2>
              </div>
              <span class="badge blue" id="expenseCountBadge">0 expenses</span>
            </div>
          </div>
          <div class="card-body">
            <div class="filter-bar">
              <input id="searchInput" placeholder="🔍 Search expenses…" />
              <select id="filterCategory">
                <option value="">All categories</option>
                <option value="food">🍽️ Food</option>
                <option value="transport">🚕 Transport</option>
                <option value="groceries">🛒 Groceries</option>
                <option value="shopping">🛍️ Shopping</option>
                <option value="accommodation">🏨 Accommodation</option>
                <option value="entertainment">🎉 Entertainment</option>
                <option value="other">🗂️ Other</option>
              </select>
              <select id="filterPayer">
                <option value="">All payers</option>
              </select>
            </div>
            <div id="expenseList" class="expense-list"></div>
            <div id="expenseEmpty" class="empty"><strong>No expenses yet</strong>Add your first shared payment above.</div>
          </div>
        </section>
      </main>

      <aside class="right">
        <!-- Final settlement (top priority) -->
        <section class="card">
          <div class="card-header">
            <div class="section-title">
              <div>
                <div class="eyebrow">Final settlement</div>
                <h2>Who pays whom?</h2>
              </div>
            </div>
          </div>
          <div class="card-body stack">
            <div class="big-result">
              <div class="eyebrow">Minimum transactions</div>
              <h3>Settle up now</h3>
              <p>The app minimizes transactions so the group can settle up faster.</p>
            </div>
            <div class="settlement-header-row">
              <span class="hint" style="margin:0">Mark each payment as done when settled.</span>
              <button class="secondary sm" id="copySettlementBtn">📋 Copy</button>
            </div>
            <div id="settlementList" class="settlement-list"></div>
            <div id="settlementEmpty" class="empty"><strong>Nothing to settle</strong>Add expenses and people to see who owes what.</div>
          </div>
        </section>

        <!-- Stats -->
        <section class="card">
          <div class="card-body stack">
            <div class="stats">
              <div class="stat">
                <div class="k">Total paid</div>
                <div class="v" id="statTotal">0.00</div>
              </div>
              <div class="stat">
                <div class="k">People</div>
                <div class="v" id="statPeople">0</div>
              </div>
              <div class="stat">
                <div class="k">Expenses</div>
                <div class="v" id="statExpenses">0</div>
              </div>
            </div>
          </div>
        </section>

        <!-- Balances -->
        <section class="card">
          <div class="card-header">
            <div class="section-title">
              <div>
                <div class="eyebrow">Balances</div>
                <h2>Net position per person</h2>
              </div>
            </div>
          </div>
          <div class="card-body">
            <div id="balanceList" class="balance-list"></div>
            <div id="balanceEmpty" class="empty" style="display:none"><strong>No data yet</strong>Add people and expenses first.</div>
          </div>
        </section>
      </aside>
    </div>

    <div class="footer-note">Data is saved locally in your browser · Split Bill Pro</div>
  </div>

  <input type="file" id="importFile" accept="application/json" hidden />

  <script>
    (() => {
      const STORAGE_KEY = 'splitBillPro_v1';

      // ─── State ─────────────────────────────────────────────────────────────
      let state = { people: [], expenses: [] };
      let currency = { code: 'TWD', symbol: 'NT$' };

      const CURRENCIES = {
        TWD: 'NT$',
        USD: '$',
        IDR: 'Rp',
        EUR: '€'
      };

      const CATEGORY_META = {
        food:          { label: 'Food',          icon: '🍽️' },
        transport:     { label: 'Transport',      icon: '🚕' },
