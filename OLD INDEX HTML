      // ─── Calculation ─────────────────────────────────────────────────────────
      function calculateSharesForExpense(expense) {
        const participants = expense.participantIds.slice();
        const amount = money(expense.amount);
        const rule = expense.rounding || 'nearest';
        const result = {};
        participants.forEach(id => result[id] = 0);
        if (!participants.length) return result;

        if (expense.mode === 'equal') {
          const base = roundWithRule(amount / participants.length, rule);
          participants.forEach((id, idx) => {
            result[id] = idx === participants.length - 1
              ? roundWithRule(amount - base * (participants.length - 1), rule) : base;
          });
          return result;
        }

        const rawTotal = participants.reduce((sum, id) => sum + money(expense.shares[id]), 0);
        if (rawTotal <= 0) {
          const fallback = roundWithRule(amount / participants.length, rule);
          participants.forEach((id, idx) => {
            result[id] = idx === participants.length - 1
              ? roundWithRule(amount - fallback * (participants.length - 1), rule) : fallback;
          });
          return result;
        }

        participants.forEach((id, idx) => {
          const raw = (money(expense.shares[id]) / rawTotal) * amount;
          result[id] = idx === participants.length - 1 ? 0 : roundWithRule(raw, rule);
        });
        const sumBeforeLast = participants.slice(0, -1).reduce((sum, id) => sum + money(result[id]), 0);
        result[participants[participants.length - 1]] = roundWithRule(amount - sumBeforeLast, rule);
        return result;
      }

      function compute() {
        const paid = {}; const owed = {};
        state.people.forEach(p => { paid[p.id] = 0; owed[p.id] = 0; });

        const expenseBreakdown = state.expenses.map(expense => {
          const shares = calculateSharesForExpense(expense);
          paid[expense.paidBy] = money(paid[expense.paidBy]) + money(expense.amount);
          Object.entries(shares).forEach(([id, share]) => { owed[id] = money(owed[id]) + money(share); });
          return { ...expense, computedShares: shares };
        });

        const balances = {};
        state.people.forEach(p => {
          balances[p.id] = roundWithRule(money(paid[p.id]) - money(owed[p.id]), 'nearest');
        });

        const settlements = settle(balances);
        const total = state.expenses.reduce((sum, e) => sum + money(e.amount), 0);
        return { paid, owed, balances, settlements, total, expenseBreakdown };
      }

      function settle(balances) {
        const creditors = [], debtors = [];
        Object.entries(balances).forEach(([id, balance]) => {
          const rounded = roundWithRule(balance, 'nearest');
          if (rounded > 0.009) creditors.push({ id, amount: rounded });
          if (rounded < -0.009) debtors.push({ id, amount: Math.abs(rounded) });
        });
        creditors.sort((a, b) => b.amount - a.amount);
        debtors.sort((a, b) => b.amount - a.amount);

        const tx = [];
        let i = 0, j = 0;
        while (i < debtors.length && j < creditors.length) {
          const send = Math.min(debtors[i].amount, creditors[j].amount);
          const amount = roundWithRule(send, 'nearest');
          if (amount <= 0) break;
          tx.push({ from: debtors[i].id, to: creditors[j].id, amount });
          debtors[i].amount = roundWithRule(debtors[i].amount - amount, 'nearest');
          creditors[j].amount = roundWithRule(creditors[j].amount - amount, 'nearest');
          if (debtors[i].amount <= 0.009) i++;
          if (creditors[j].amount <= 0.009) j++;
        }
        return tx;
      }

      // ─── Render: People ──────────────────────────────────────────────────────
      function renderPeople() {
        const calc = compute();
