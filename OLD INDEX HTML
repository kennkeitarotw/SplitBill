                </div>
              </div>
              <div class="expense-bottom">
                <div class="chips">${chips}</div>
                <div class="muted" style="font-size:12px;text-align:right;font-family:'DM Mono',monospace">${sharesText}</div>
              </div>
              <!-- Inline edit form -->
              <div class="inline-edit-form" id="edit-form-${expense.id}">
                <div class="stack">
                  <div class="grid-3">
                    <div class="input-group"><label>Name</label><input data-edit="title" value="${escapeHtml(expense.title)}" /></div>
                    <div class="input-group"><label>Amount</label><input type="number" step="0.01" min="0" data-edit="amount" value="${expense.amount}" /></div>
