                  </div>
                  <div class="input-group"><label>Note</label><input data-edit="note" value="${escapeHtml(expense.note||'')}" placeholder="Optional note" /></div>
                  <div class="input-group"><label>Split among</label><div class="checkbox-grid">${participantChecks}</div></div>
                  <div class="grid-2">
                    <div class="input-group"><label>Split mode</label>
                      <select data-edit="splitMode">
                        <option value="equal"${expense.mode==='equal'?' selected':''}>Equal</option>
